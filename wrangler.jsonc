{
  // 静的エクスポート（out/）をそのまま配信する Workers Static Assets 設定。
  // これがあることで `wrangler deploy` は OpenNext(SSR) 変換をスキップし、
  // next build が出力した out/ の静的ファイルをアップロードする。
  "name": "atsuya-maya-portfolio",
  "compatibility_date": "2026-07-05",
  "assets": {
    "directory": "./out",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
